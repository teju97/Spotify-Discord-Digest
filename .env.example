# Spotify — create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/callback

# Discord Option 1 — Incoming Webhook (simpler, no auth)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here

# Discord Option 2 — Bot API (explicit authentication with Bot token)
# If both options are set, the Bot API takes precedence
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# Server
PORT=3000

# These are populated automatically after you run the /auth flow
SPOTIFY_REFRESH_TOKEN=

# Discord Bot 
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here